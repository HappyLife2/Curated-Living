# Curated Living — runtime environment. Copy to .env on the server; never commit .env.

# Public site URL (used for metadata, sitemap, canonical). Update once the domain is registered.
NEXT_PUBLIC_SITE_URL=https://curatedlivingdubai.com

# Microsoft Clarity project ID (heatmaps + session recordings). Leave blank to ship without tracking.
NEXT_PUBLIC_CLARITY_ID=

# Resend (contact form). Leave blank to disable sending (form still validates + logs).
RESEND_API_KEY=
# Where enquiries are delivered (Melissa's inbox until a brand inbox is live):
CONTACT_TO=melissa.madonna95@gmail.com
# Verified sender (must be a domain verified in Resend), e.g. hello@curatedlivingdubai.com
CONTACT_FROM=Curated Living <onboarding@resend.dev>
